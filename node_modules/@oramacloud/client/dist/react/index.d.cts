import { SearchParams, AnyOrama, Nullable, Results, AnyDocument } from '@orama/orama';
import React from 'react';

type SearchMode = 'fulltext' | 'vector' | 'hybrid';
type AdditionalSearchParams = {
    mode: SearchMode;
    returning?: string[];
};
type ClientSearchParams = SearchParams<AnyOrama> & AdditionalSearchParams;

interface UseSearch {
    ready: boolean;
    results: Nullable<Results<AnyDocument>>;
    error: Nullable<Error>;
}
declare const OramaCloud: ({ children, endpoint, apiKey }: {
    children: React.ReactNode;
    endpoint: string;
    apiKey: string;
}) => JSX.Element;
declare function useSearch(query: ClientSearchParams): UseSearch;

export { OramaCloud, useSearch };
