    debounce?: number;
}
type SearchMode = 'fulltext' | 'vector' | 'hybrid';
type AdditionalSearchParams = {
    mode: SearchMode;
    returning?: string[];
};
type ClientSearchParams = SearchParams<AnyOrama> & AdditionalSearchParams;
declare class OramaClient {
